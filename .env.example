# Site
NEXT_PUBLIC_SITE_URL=https://shwetasinghrealty.com

# EspoCRM (primary lead destination)
ESPOCRM_URL=https://crm.shwetasinghrealty.com
ESPOCRM_API_KEY=your_espocrm_api_key
ESPOCRM_SHWETA_USER_ID=user_uuid_from_espocrm

# Resend (email fallback when EspoCRM is unavailable)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=leads@shwetasinghrealty.com
LEAD_NOTIFICATION_EMAIL=shweta@shwetasinghrealty.com

# Umami Analytics
NEXT_PUBLIC_UMAMI_WEBSITE_ID=uuid_from_umami_dashboard
NEXT_PUBLIC_UMAMI_URL=https://analytics.shwetasinghrealty.com

# SimplyRETS IDX (live MLS listings)
# Sandbox credentials for testing: key=simplyrets secret=simplyrets
SIMPLYRETS_KEY=your_simplyrets_key
SIMPLYRETS_SECRET=your_simplyrets_secret
# Optional: override default city/county filters
# SIMPLYRETS_DEFAULT_CITIES=Buford,Suwanee,Duluth,Lawrenceville,Sugar Hill,Cumming
# SIMPLYRETS_DEFAULT_COUNTIES=Gwinnett,Forsyth
